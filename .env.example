# Web Studio — Brief App
# These values are surfaced to the static frontend via env-config.js (window.__env).
# Copy to `.env` and fill in. On Netlify, set the same keys as environment variables
# and generate env-config.js at build time (see README — "Deploy en Netlify").

SUPABASE_URL=
SUPABASE_ANON_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
INVESTIGATOR_PIN=
